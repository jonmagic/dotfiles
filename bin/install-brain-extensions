#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PACKAGES_DIR="$DOTFILES_DIR/packages"
VSCODE_DIR="$PACKAGES_DIR/vscode"
RAYCAST_DIR="$PACKAGES_DIR/raycast"

if ! command -v bun >/dev/null 2>&1; then
  echo "bun is required but was not found on PATH."
  exit 1
fi

if ! command -v code-insiders >/dev/null 2>&1; then
  echo "VS Code Insiders CLI 'code-insiders' was not found on PATH."
  echo "Open VS Code Insiders and run: Shell Command: Install 'code-insiders' command in PATH"
  exit 1
fi

if [[ ! -d "$PACKAGES_DIR" ]]; then
  echo "Packages directory not found: $PACKAGES_DIR"
  exit 1
fi

# Install dependencies for the workspace
(
  cd "$PACKAGES_DIR"
  bun install
)

# Build shared core + VS Code extension bundle
(
  cd "$PACKAGES_DIR"
  bun run build
)

# Package VS Code extension as a VSIX (stage outside git repo to avoid git file listing)
VSIX_DIR="$VSCODE_DIR/.artifacts"
VSIX_PATH="$VSIX_DIR/jonmagic-brain.vsix"
mkdir -p "$VSIX_DIR"

TMP_VSCODE_DIR="$(mktemp -d)"
cleanup_tmp() {
  rm -rf "$TMP_VSCODE_DIR"
}
trap cleanup_tmp EXIT

rsync -a --delete \
  --exclude "node_modules" \
  --exclude ".git" \
  --exclude ".artifacts" \
  "$VSCODE_DIR/" "$TMP_VSCODE_DIR/"

(
  cd "$TMP_VSCODE_DIR"
  bunx @vscode/vsce package -o "$VSIX_PATH" --no-dependencies
)

# Install VS Code extension (Insiders)
code-insiders --install-extension "$VSIX_PATH" --force

# Install Raycast extension by syncing to the local extensions dir
RAYCAST_EXT_DIR="$HOME/.raycast/extensions"
mkdir -p "$RAYCAST_EXT_DIR"

RAYCAST_NAME=$(
  RAYCAST_DIR="$RAYCAST_DIR" \
  node -e "const fs=require('fs');const path=require('path');const dir=process.env.RAYCAST_DIR;const data=JSON.parse(fs.readFileSync(path.join(dir,'raycast.json'),'utf8'));process.stdout.write(data.name);"
)

if [[ -z "$RAYCAST_NAME" ]]; then
  echo "Could not read Raycast extension name from raycast.json"
  exit 1
fi

TARGET_DIR="$RAYCAST_EXT_DIR/$RAYCAST_NAME"
mkdir -p "$TARGET_DIR"
rsync -a --delete "$RAYCAST_DIR/" "$TARGET_DIR/"

echo "Installed VS Code extension (Insiders): jonmagic.jonmagic-brain"
echo "Installed Raycast extension at: $TARGET_DIR"
echo "If it doesn't show in Raycast yet, run: bunx @raycast/api@latest develop -I (from $TARGET_DIR)"
