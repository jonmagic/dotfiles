#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PACKAGES_DIR="$DOTFILES_DIR/packages"
VSCODE_DIR="$PACKAGES_DIR/vscode"
RAYCAST_DIR="$PACKAGES_DIR/raycast"

# Uninstall VS Code extension if possible (Insiders)
if command -v code-insiders >/dev/null 2>&1; then
  code-insiders --uninstall-extension jonmagic.jonmagic-brain || true
else
  echo "VS Code Insiders CLI 'code-insiders' not found; skipping VS Code uninstall."
fi

# Remove packaged VSIX artifact
if [[ -d "$VSCODE_DIR/.artifacts" ]]; then
  rm -rf "$VSCODE_DIR/.artifacts"
fi

# Remove Raycast extension from local extensions directory
RAYCAST_EXT_DIR="$HOME/.raycast/extensions"
if [[ -d "$RAYCAST_EXT_DIR" ]]; then
  RAYCAST_NAME=$(
    RAYCAST_DIR="$RAYCAST_DIR" \
    node -e "const fs=require('fs');const path=require('path');const dir=process.env.RAYCAST_DIR;const data=JSON.parse(fs.readFileSync(path.join(dir,'raycast.json'),'utf8'));process.stdout.write(data.name);"
  )

  if [[ -n "$RAYCAST_NAME" ]]; then
    TARGET_DIR="$RAYCAST_EXT_DIR/$RAYCAST_NAME"
    if [[ -e "$TARGET_DIR" ]]; then
      rm -rf "$TARGET_DIR"
    fi
  fi
fi

# Remove any legacy install under Raycast app support (best-effort)
LEGACY_EXT_DIR="$HOME/Library/Application Support/com.raycast.macos/extensions"
if [[ -d "$LEGACY_EXT_DIR" ]]; then
  if [[ -n "${RAYCAST_NAME:-}" ]]; then
    LEGACY_TARGET="$LEGACY_EXT_DIR/$RAYCAST_NAME"
    if [[ -e "$LEGACY_TARGET" ]]; then
      rm -rf "$LEGACY_TARGET"
    fi
  fi
fi

echo "Uninstalled VS Code extension (Insiders): jonmagic.jonmagic-brain"
echo "Removed Raycast extension (if present)."
