#!/usr/bin/env zsh
set -uo pipefail

# Update all software on this machine, then hand the output to Copilot CLI
# for analysis and follow-up.

BREWFILE="$HOME/.dotfiles/brew/Brewfile"
LOG=$(mktemp)
UPDATE_MODE="safe"
RUN_BREW_CLEANUP=0
SKIP_MAS=0
SKIP_MISE=0
trap "rm -f $LOG" EXIT

usage() {
  cat <<'EOF'
Usage: update-software [--all] [--cleanup] [--no-mas] [--no-mise]

Without flags, runs safer defaults:
  - updates Copilot CLI, Homebrew core formulae, mise, and Mac App Store apps
  - reports but defers broad non-Copilot plugin/package/cask updates
  - never runs destructive Brewfile cleanup

Safe mode updates:
  - Copilot CLI prerelease
  - Homebrew core formulae
  - mise-managed runtimes/tools
  - Mac App Store apps, except known skipped app ids

--all additionally updates:
  - Antigen plugins
  - gh extensions
  - global npm packages
  - third-party and unclassified Homebrew formulae
  - Homebrew casks
  - llm GitHub Copilot plugin from PyPI

Options:
  --safe        Run the default safer update pass
  --all, --full Include deferred non-Copilot update lanes for this run
  --cleanup     Remove software not listed in the Brewfile after updating
  --no-mas      Skip Mac App Store updates
  --no-mise     Skip mise runtime/tool updates
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --all|--full)
      UPDATE_MODE="all"
      ;;
    --safe)
      UPDATE_MODE="safe"
      ;;
    --cleanup)
      RUN_BREW_CLEANUP=1
      ;;
    --no-mas)
      SKIP_MAS=1
      ;;
    --no-mise)
      SKIP_MISE=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
  shift
done

# Tee all output so the user sees it live AND we capture it for Copilot.
{
  run_step() {
    local name="$1"
    local step_status=0
    shift
    echo "==> $name"
    "$@" || step_status=$?
    if (( step_status != 0 )); then
      echo "Step failed with exit code $step_status."
    fi
    echo ""
    return 0
  }

  skip_step() {
    local name="$1"
    local reason="$2"
    echo "==> $name"
    echo "$reason; skipping."
    echo ""
  }

  all_updates_enabled() {
    [[ "$UPDATE_MODE" == "all" ]]
  }

  deferred_step() {
    local name="$1"
    local reason="$2"
    shift 2

    if all_updates_enabled; then
      run_step "$name" "$@"
    else
      skip_step "$name" "$reason; run update-software --all to include it"
    fi
  }

  homebrew_formula_tap() {
    brew info --json=v2 --formula "$1" |
      ruby -rjson -e 'formula = JSON.parse(STDIN.read).fetch("formulae").first; puts formula["tap"].to_s'
  }

  trust_homebrew_bundle_formulae() {
    local formulae=""
    local formula=""
    local trust_status=0

    if [[ ! -f "$BREWFILE" ]]; then
      return 0
    fi

    if ! brew trust --help >/dev/null 2>&1; then
      return 0
    fi

    formulae="$(sed -nE 's/^[[:space:]]*brew[[:space:]]+"([^"]+\/[^"]+\/[^"]+)".*/\1/p' "$BREWFILE")"
    if [[ -z "${formulae//[[:space:]]/}" ]]; then
      return 0
    fi

    echo "Trusting Brewfile-scoped third-party formulae:"
    while IFS= read -r formula; do
      [[ -n "$formula" ]] || continue
      echo " - $formula"
      brew trust --formula "$formula" || trust_status=$?
    done <<< "$formulae"
    echo ""

    return $trust_status
  }

  upgrade_homebrew_formulae() {
    local outdated_formulae=""
    local formula=""
    local tap=""
    local -a core_formulae=()
    local -a third_party_formulae=()
    local -a unclassified_formulae=()

    outdated_formulae="$(brew outdated --formula)"
    if [[ -z "${outdated_formulae//[[:space:]]/}" ]]; then
      echo "All Homebrew formulae are up to date."
      return 0
    fi

    echo "Outdated Homebrew formulae:"
    printf '%s\n' "$outdated_formulae"
    echo ""

    while IFS= read -r formula; do
      [[ -n "$formula" ]] || continue

      tap="$(homebrew_formula_tap "$formula" 2>/dev/null || true)"
      if [[ "$tap" == "homebrew/core" ]]; then
        core_formulae+=("$formula")
      elif [[ -z "$tap" ]]; then
        unclassified_formulae+=("$formula")
      else
        third_party_formulae+=("$formula")
      fi
    done <<< "$outdated_formulae"

    if (( ${#core_formulae[@]} != 0 )); then
      echo "Upgrading Homebrew core formulae:"
      printf ' - %s\n' "${core_formulae[@]}"
      brew upgrade --formula "${core_formulae[@]}"
    else
      echo "No outdated Homebrew core formulae."
    fi

    if (( ${#third_party_formulae[@]} != 0 )); then
      echo ""
      if all_updates_enabled; then
        echo "Upgrading third-party Homebrew formulae:"
        printf ' - %s\n' "${third_party_formulae[@]}"
        brew upgrade --formula "${third_party_formulae[@]}"
      else
        echo "Skipped third-party Homebrew formulae:"
        printf ' - %s\n' "${third_party_formulae[@]}"
        echo "Run update-software --all to include them."
      fi
    fi

    if (( ${#unclassified_formulae[@]} != 0 )); then
      echo ""
      if all_updates_enabled; then
        echo "Upgrading unclassified Homebrew formulae:"
        printf ' - %s\n' "${unclassified_formulae[@]}"
        brew upgrade --formula "${unclassified_formulae[@]}"
      else
        echo "Skipped unclassified Homebrew formulae:"
        printf ' - %s\n' "${unclassified_formulae[@]}"
        echo "Run update-software --all to include them."
      fi
    fi
  }

  upgrade_homebrew_casks() {
    local outdated_casks=""
    local -a cask_list=()

    outdated_casks="$(brew outdated --cask)"
    if [[ -z "${outdated_casks//[[:space:]]/}" ]]; then
      echo "All Homebrew casks are up to date."
      return 0
    fi

    echo "Outdated Homebrew casks:"
    printf '%s\n' "$outdated_casks"
    echo ""

    if all_updates_enabled; then
      cask_list=("${(@f)outdated_casks}")
      brew upgrade --cask "${cask_list[@]}"
    else
      echo "Skipped Homebrew casks."
      echo "Run update-software --all to include them."
    fi
  }

  upgrade_homebrew() {
    local trust_status=0

    brew update

    trust_homebrew_bundle_formulae || trust_status=$?
    if (( trust_status != 0 )); then
      echo "One or more Brewfile-scoped formulae could not be trusted; Homebrew may still require manual trust."
      echo ""
    fi

    upgrade_homebrew_formulae
    echo ""
    upgrade_homebrew_casks

    if (( RUN_BREW_CLEANUP != 0 )); then
      brew bundle cleanup --force --file="$BREWFILE"
    else
      echo ""
      echo "Brewfile cleanup disabled by default; run update-software --cleanup to remove software not listed in $BREWFILE."
    fi
  }

  # 1. Antigen
  if [[ -f "$HOME/.dotfiles/sources/terminal" ]]; then
    deferred_step "Upgrading antigen plugins" "direct GitHub plugin updates are deferred by the safe default" zsh -lc 'source "$HOME/.dotfiles/sources/terminal" && antigen update'
  else
    skip_step "Upgrading antigen plugins" "terminal config not found at ~/.dotfiles/sources/terminal"
  fi

  # 2. gh extensions
  if command -v gh &>/dev/null; then
    deferred_step "Upgrading gh extensions" "GitHub extension updates are deferred by the safe default" gh extension upgrade --all
  else
    skip_step "Upgrading gh extensions" "GitHub CLI not installed"
  fi

  # 3. Global npm packages
  if command -v npm &>/dev/null; then
    deferred_step "Upgrading global npm packages" "blanket global npm updates are deferred by the safe default" npm update -g
  else
    skip_step "Upgrading global npm packages" "npm not installed"
  fi

  # 4. mise packages
  if command -v mise &>/dev/null; then
    if (( SKIP_MISE != 0 )); then
      skip_step "Upgrading mise packages" "disabled by --no-mise"
    else
      run_step "Upgrading mise packages" mise upgrade
    fi
  else
    skip_step "Upgrading mise packages" "mise not installed"
  fi

  # 5. Homebrew
  if command -v brew &>/dev/null; then
    run_step "Upgrading homebrew" upgrade_homebrew
  else
    skip_step "Upgrading homebrew" "Homebrew not installed"
  fi

  upgrade_mas_apps() {
    local mas_bin=""
    local outdated_apps=""
    local outdated_status=0
    local skip_app_ids_raw="${UPDATE_SOFTWARE_SKIP_MAS_APP_IDS:-}"
    local app_line=""
    local app_id=""
    # Push Security is employer-installed and tied to a different Apple Account.
    local -a skip_app_ids=("1596916655")
    local -a mas_cmd=()
    local -a outdated_app_lines=()
    local -a updatable_app_lines=()
    local -a failed_apps=()
    local -a skipped_apps=()

    mas_bin="$(command -v mas)"
    mas_cmd=(env MAS_NO_AUTO_INDEX=1 "$mas_bin")

    if (( SKIP_MAS != 0 )); then
      echo "Mac App Store upgrades disabled by --no-mas."
      return 0
    fi

    skip_app_ids_raw="${skip_app_ids_raw//,/ }"
    if [[ -n "${skip_app_ids_raw//[[:space:]]/}" ]]; then
      skip_app_ids+=(${=skip_app_ids_raw})
    fi

    outdated_apps="$("${mas_cmd[@]}" outdated 2>&1)"
    outdated_status=$?

    if (( outdated_status != 0 )); then
      echo "$outdated_apps"
      return $outdated_status
    fi

    if [[ -n "${outdated_apps//[[:space:]]/}" ]]; then
      echo "$outdated_apps"
    fi

    while IFS= read -r app_line; do
      [[ "$app_line" == <->\ * ]] || continue
      outdated_app_lines+=("$app_line")
    done <<< "$outdated_apps"

    if (( ${#outdated_app_lines[@]} == 0 )); then
      echo "All Mac App Store apps are up to date."
      return 0
    fi

    for app_line in "${outdated_app_lines[@]}"; do
      app_id="${app_line%% *}"

      if (( ${skip_app_ids[(Ie)$app_id]} != 0 )); then
        skipped_apps+=("$app_line")
      else
        updatable_app_lines+=("$app_line")
      fi
    done

    if (( ${#updatable_app_lines[@]} == 0 )); then
      echo ""
      echo "Skipped Mac App Store updates:"
      printf ' - %s\n' "${skipped_apps[@]}"
      return 0
    fi

    if ! sudo -v; then
      echo "Unable to authenticate sudo; skipping Mac App Store upgrades."
      return 1
    fi

    for app_line in "${updatable_app_lines[@]}"; do
      app_id="${app_line%% *}"

      echo ""
      echo "Updating $app_line"

      if ! sudo env MAS_NO_AUTO_INDEX=1 "$mas_bin" upgrade "$app_id"; then
        echo "Resetting App Store state and retrying $app_id..."
        env MAS_NO_AUTO_INDEX=1 "$mas_bin" reset

        if ! sudo env MAS_NO_AUTO_INDEX=1 "$mas_bin" upgrade "$app_id"; then
          failed_apps+=("$app_line")
        fi
      fi
    done

    if (( ${#skipped_apps[@]} != 0 )); then
      echo ""
      echo "Skipped Mac App Store updates:"
      printf ' - %s\n' "${skipped_apps[@]}"
    fi

    if (( ${#failed_apps[@]} != 0 )); then
      echo ""
      echo "Failed Mac App Store updates:"
      printf ' - %s\n' "${failed_apps[@]}"
      echo "These usually need a manual App Store retry or the Apple Account that originally installed the app."
      return 1
    fi
  }

  # 7. llm plugins
  if command -v llm &>/dev/null; then
    llm_bin="$(command -v llm)"
    deferred_step "Upgrading llm GitHub Copilot plugin" "PyPI plugin updates are deferred by the safe default" "$llm_bin" install --upgrade llm-github-copilot
  else
    skip_step "Upgrading llm GitHub Copilot plugin" "llm not installed"
  fi

  # 8. Mac App Store
  if command -v mas &>/dev/null; then
    run_step "Upgrading Mac App Store apps" upgrade_mas_apps
  else
    skip_step "Upgrading Mac App Store apps" "mas CLI not installed"
  fi

  # 9. Copilot CLI (standalone npm install, not the gh extension)
  if command -v npm &>/dev/null; then
    run_step "Upgrading Copilot CLI" npm install -g @github/copilot@prerelease
  else
    skip_step "Upgrading Copilot CLI" "npm not installed"
  fi

} 2>&1 | tee "$LOG"

# Phase 2: Hand the captured output to Copilot for analysis and follow-ups.
echo ""
echo "==> Analyzing update results with Copilot..."
echo ""

gh copilot -p "
Here is the output from my software update script. Please:
1. Summarize what was updated, what was already up to date, and what was skipped.
2. Flag any errors, warnings, or deprecation notices that need attention.
3. If there are actionable follow-up items (e.g. deprecated packages to replace,
   failed updates to retry, security notices), list them clearly.

Known intentional behavior:
- Push Security Mac App Store app id 1596916655 is employer-installed and tied
  to a different Apple Account, so the script intentionally skips it.
- Copilot CLI prerelease updates are an accepted-risk fast lane and should stay
  automatic.
- Safe mode is the default. It updates Copilot CLI, Homebrew core formulae,
  mise, and Mac App Store apps, while deferring broad non-Copilot plugin,
  package, third-party Homebrew, unclassified Homebrew, and cask updates.
- Deferred safe-mode lanes are not failures. Suggest update-software --all only
  when the user intentionally wants the broader update pass.
- Brewfile cleanup is destructive and intentionally opt-in with
  update-software --cleanup.

Output:
$(cat "$LOG")
" --allow-tool shell --disable-builtin-mcps --no-ask-user --model claude-sonnet-4.5

# Clean up ephemeral sessions from session-store.db
SESSION_DB="$HOME/.copilot/session-store.db"
if [[ -f "$SESSION_DB" ]]; then
  sqlite3 "$SESSION_DB" "
    DELETE FROM search_index WHERE session_id IN (SELECT id FROM sessions WHERE summary LIKE 'Here is the output from my software update%' OR summary = 'Summarize Update Script Output');
    DELETE FROM session_refs WHERE session_id IN (SELECT id FROM sessions WHERE summary LIKE 'Here is the output from my software update%' OR summary = 'Summarize Update Script Output');
    DELETE FROM session_files WHERE session_id IN (SELECT id FROM sessions WHERE summary LIKE 'Here is the output from my software update%' OR summary = 'Summarize Update Script Output');
    DELETE FROM checkpoints WHERE session_id IN (SELECT id FROM sessions WHERE summary LIKE 'Here is the output from my software update%' OR summary = 'Summarize Update Script Output');
    DELETE FROM turns WHERE session_id IN (SELECT id FROM sessions WHERE summary LIKE 'Here is the output from my software update%' OR summary = 'Summarize Update Script Output');
    DELETE FROM sessions WHERE summary LIKE 'Here is the output from my software update%' OR summary = 'Summarize Update Script Output';
  " 2>/dev/null
fi
