#!/usr/bin/env zsh
set -uo pipefail

# Update all software on this machine, then hand the output to Copilot CLI
# for analysis and follow-up.

BREWFILE="$HOME/.dotfiles/brew/Brewfile"
LOG=$(mktemp)
trap "rm -f $LOG" EXIT

# Tee all output so the user sees it live AND we capture it for Copilot.
{
  run_step() {
    local name="$1"
    local step_status=0
    shift
    echo "==> $name"
    "$@" || step_status=$?
    if (( step_status != 0 )); then
      echo "Step failed with exit code $step_status."
    fi
    echo ""
    return 0
  }

  skip_step() {
    local name="$1"
    local reason="$2"
    echo "==> $name"
    echo "$reason; skipping."
    echo ""
  }

  # 1. Antigen
  if [[ -f "$HOME/.dotfiles/sources/terminal" ]]; then
    run_step "Upgrading antigen plugins" zsh -lc 'source "$HOME/.dotfiles/sources/terminal" && antigen update'
  else
    skip_step "Upgrading antigen plugins" "terminal config not found at ~/.dotfiles/sources/terminal"
  fi

  # 2. gh extensions
  if command -v gh &>/dev/null; then
    run_step "Upgrading gh extensions" gh extension upgrade --all
  else
    skip_step "Upgrading gh extensions" "GitHub CLI not installed"
  fi

  # 3. asdf plugins
  if command -v asdf &>/dev/null; then
    run_step "Upgrading asdf plugins" asdf plugin update --all
  else
    skip_step "Upgrading asdf plugins" "asdf not installed"
  fi

  # 4. Global npm packages
  if command -v npm &>/dev/null; then
    run_step "Upgrading global npm packages" npm update -g
  else
    skip_step "Upgrading global npm packages" "npm not installed"
  fi

  # 5. mise packages
  if command -v mise &>/dev/null; then
    run_step "Upgrading mise packages" mise upgrade
  else
    skip_step "Upgrading mise packages" "mise not installed"
  fi

  # 6. Homebrew
  if command -v brew &>/dev/null; then
    echo "==> Upgrading homebrew"
    brew update && brew outdated && brew upgrade && brew bundle cleanup --force --no-vscode --file="$BREWFILE"
    echo ""
  else
    skip_step "Upgrading homebrew" "Homebrew not installed"
  fi

  upgrade_mas_apps() {
    local mas_bin=""
    local outdated_apps=""
    local outdated_status=0
    local app_line=""
    local app_id=""
    local -a mas_cmd=()
    local -a outdated_app_lines=()
    local -a failed_apps=()

    mas_bin="$(command -v mas)"
    mas_cmd=(env MAS_NO_AUTO_INDEX=1 "$mas_bin")

    outdated_apps="$("${mas_cmd[@]}" outdated 2>&1)"
    outdated_status=$?

    if (( outdated_status != 0 )); then
      echo "$outdated_apps"
      return $outdated_status
    fi

    if [[ -n "${outdated_apps//[[:space:]]/}" ]]; then
      echo "$outdated_apps"
    fi

    while IFS= read -r app_line; do
      [[ "$app_line" == <->\ * ]] || continue
      outdated_app_lines+=("$app_line")
    done <<< "$outdated_apps"

    if (( ${#outdated_app_lines[@]} == 0 )); then
      echo "All Mac App Store apps are up to date."
      return 0
    fi

    if ! sudo -v; then
      echo "Unable to authenticate sudo; skipping Mac App Store upgrades."
      return 1
    fi

    for app_line in "${outdated_app_lines[@]}"; do
      app_id="${app_line%% *}"

      echo ""
      echo "Updating $app_line"

      if ! sudo env MAS_NO_AUTO_INDEX=1 "$mas_bin" upgrade "$app_id"; then
        echo "Resetting App Store state and retrying $app_id..."
        env MAS_NO_AUTO_INDEX=1 "$mas_bin" reset

        if ! sudo env MAS_NO_AUTO_INDEX=1 "$mas_bin" upgrade "$app_id"; then
          failed_apps+=("$app_line")
        fi
      fi
    done

    if (( ${#failed_apps[@]} != 0 )); then
      echo ""
      echo "Failed Mac App Store updates:"
      printf ' - %s\n' "${failed_apps[@]}"
      echo "These usually need a manual App Store retry or the Apple Account that originally installed the app."
      return 1
    fi
  }

  # 7. Mac App Store
  if command -v mas &>/dev/null; then
    run_step "Upgrading Mac App Store apps" upgrade_mas_apps
  else
    skip_step "Upgrading Mac App Store apps" "mas CLI not installed"
  fi

  # 8. Copilot CLI
  if command -v gh &>/dev/null; then
    run_step "Upgrading Copilot CLI" gh copilot -- update
  else
    skip_step "Upgrading Copilot CLI" "GitHub CLI not installed"
  fi

} 2>&1 | tee "$LOG"

# Phase 2: Hand the captured output to Copilot for analysis and follow-ups.
echo ""
echo "==> Analyzing update results with Copilot..."
echo ""

gh copilot -p "
Here is the output from my software update script. Please:
1. Summarize what was updated, what was already up to date, and what was skipped.
2. Flag any errors, warnings, or deprecation notices that need attention.
3. If there are actionable follow-up items (e.g. deprecated packages to replace,
   failed updates to retry, security notices), list them clearly.

Output:
$(cat "$LOG")
" --allow-tool shell --disable-builtin-mcps --no-ask-user --model claude-sonnet-4.5
