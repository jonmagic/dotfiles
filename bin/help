#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ALIASES_FILE="$ROOT_DIR/sources/aliases"
FUNCTIONS_FILE="$ROOT_DIR/sources/functions.zsh"
BIN_DIR="$ROOT_DIR/bin"

PLAIN_OUTPUT=0
STARTUP_MODE=0
QUERY=""

usage() {
  cat <<'EOF'
Usage: help [all|aliases|functions|scripts|ollama|command-name] [--plain]

Without arguments, prints the workflow-focused dotfiles command guide.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --plain)
      PLAIN_OUTPUT=1
      ;;
    --startup)
      STARTUP_MODE=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      if [[ -n "$QUERY" ]]; then
        usage >&2
        exit 1
      fi
      QUERY="$1"
      ;;
  esac
  shift
done

if [[ $PLAIN_OUTPUT -eq 0 && -t 1 && -z "${NO_COLOR:-}" ]]; then
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  BLUE=$'\033[34m'
  CYAN=$'\033[36m'
  YELLOW=$'\033[33m'
  RESET=$'\033[0m'
else
  BOLD=""
  DIM=""
  BLUE=""
  CYAN=""
  YELLOW=""
  RESET=""
fi

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT
RECORDS_FILE="$TMP_DIR/records.tsv"
QUERY_LOWER="$(printf '%s' "$QUERY" | tr '[:upper:]' '[:lower:]')"

humanize_name() {
  local value="${1//[-_.]/ }"
  awk '{
    for (i = 1; i <= NF; i++) {
      $i = toupper(substr($i, 1, 1)) substr($i, 2)
    }
    print
  }' <<<"$value"
}

script_override_description() {
  case "$1" in
    brain-commit) printf '%s\n' "Run the Brain auto-commit workflow" ;;
    copilot) printf '%s\n' "GitHub Copilot CLI (pinned to global mise node)" ;;
    fixcs) printf '%s\n' "Repair GitHub Codespaces port forwarding" ;;
    fixorb) printf '%s\n' "Repair OrbStack when it is stuck in Starting" ;;
    help) printf '%s\n' "Show the dotfiles command guide" ;;
    llm) printf '%s\n' "Run a single-shot GitHub Copilot prompt through llm" ;;
    ollama-service) printf '%s\n' "Manage the on-demand Ollama launchd service" ;;
    path) printf '%s\n' "Print PATH entries one per line" ;;
    repo) printf '%s\n' "Open the current repo origin in a browser" ;;
    tailscale) printf '%s\n' "Wrapper for the Tailscale CLI" ;;
    ts-stop) printf '%s\n' "Stop work Tailscale or the personal OrbStack tailnet" ;;
    tsp) printf '%s\n' "Start the personal OrbStack tailnet" ;;
    tsp-copy-id) printf '%s\n' "Install a macOS SSH public key through the personal OrbStack tailnet" ;;
    tsp-socks) printf '%s\n' "Start a SOCKS proxy through the personal OrbStack tailnet" ;;
    tsp-ssh) printf '%s\n' "SSH through the personal OrbStack tailnet" ;;
    tsw) printf '%s\n' "Start the work Tailscale profile" ;;
    update-software) printf '%s\n' "Update software and hand the results to Copilot" ;;
    *) return 1 ;;
  esac
}

script_description() {
  local file="$1"
  local base
  local description=""

  base="$(basename "$file")"

  if description="$(script_override_description "$base" 2>/dev/null)"; then
    printf '%s\n' "$description"
    return 0
  fi

  description="$(awk '
    function trim(value) {
      sub(/^[[:space:]]+/, "", value)
      sub(/[[:space:]]+$/, "", value)
      return value
    }

    NR == 1 && /^#!/ { next }

    /^[[:space:]]*#/ {
      line = $0
      sub(/^[[:space:]]*#[[:space:]]?/, "", line)
      line = trim(line)

      if (line == "" || line ~ /^!/ || line ~ /^@raycast\./ || line ~ /^Required parameters:/ || line ~ /^Optional parameters:/ || line ~ /^Usage:/) {
        next
      }

      print line
      exit
    }

    /^[[:space:]]*$/ { next }
    { exit }
  ' "$file")"

  if [[ -n "$description" ]]; then
    printf '%s\n' "$description"
  else
    humanize_name "$base"
  fi
}

collect_shell_records() {
  awk -v root="$ROOT_DIR" '
    function trim(value) {
      sub(/^[[:space:]]+/, "", value)
      sub(/[[:space:]]+$/, "", value)
      return value
    }

    function clean_value(value) {
      value = trim(value)
      if ((value ~ /^".*"$/) || (value ~ /^'\''.*'\''$/)) {
        value = substr(value, 2, length(value) - 2)
      }
      return value
    }

    function titleize(value,    pieces, count, i, word, result) {
      gsub(/[-_.]/, " ", value)
      count = split(value, pieces, /[[:space:]]+/)
      result = ""
      for (i = 1; i <= count; i++) {
        word = pieces[i]
        if (word == "") {
          continue
        }
        word = toupper(substr(word, 1, 1)) substr(word, 2)
        result = result (result ? " " : "") word
      }
      return result
    }

    BEGIN {
      comment = ""
    }

    FNR == 1 {
      comment = ""
    }

    /^[[:space:]]*#/ {
      text = $0
      sub(/^[[:space:]]*#[[:space:]]?/, "", text)
      text = trim(text)
      if (text != "" && text !~ /^(if[[:space:]]|fi$|then$|else$|elif[[:space:]]|alias[[:space:]]|function[[:space:]]|local[[:space:]]|case[[:space:]]|esac$|for[[:space:]]|while[[:space:]]|do$)/) {
        comment = text
      }
      next
    }

    /^[[:space:]]*$/ {
      comment = ""
      next
    }

    {
      file = FILENAME
      sub("^" root "/?", "", file)
    }

    /^[[:space:]]*alias[[:space:]]+[A-Za-z0-9_.-]+=/ {
      name = $0
      sub(/^[[:space:]]*alias[[:space:]]+/, "", name)
      sub(/=.*/, "", name)
      value = $0
      sub(/^[[:space:]]*alias[[:space:]]+[A-Za-z0-9_.-]+=/, "", value)
      value = clean_value(value)
      description = comment ? comment : value
      print "alias\t" name "\t" description "\t" value "\t" file
      next
    }

    /^[[:space:]]*(function[[:space:]]+)?[A-Za-z0-9_.-]+[[:space:]]*\(\)[[:space:]]*\{/ {
      name = $0
      sub(/^[[:space:]]*function[[:space:]]+/, "", name)
      sub(/[[:space:]]*\(\)[[:space:]]*\{.*/, "", name)
      name = trim(name)
      if (name == "command_exists" || name == "executable_exists" || name ~ /^_/) {
        next
      }
      description = comment ? comment : titleize(name)
      print "function\t" name "\t" description "\t(shell function)\t" file
      next
    }
  ' "$ALIASES_FILE" "$FUNCTIONS_FILE" >>"$RECORDS_FILE"
}

collect_script_records() {
  while IFS= read -r file; do
    local name="${file##*/}"
    local description
    description="$(script_description "$file")"
    printf 'script\t%s\t%s\t%s\t%s\n' \
      "$name" \
      "$description" \
      "$ROOT_DIR/bin/$name" \
      "${file#$ROOT_DIR/}" >>"$RECORDS_FILE"
  done < <(find "$BIN_DIR" -maxdepth 1 -type f -perm -u+x ! -name '.*' | sort)
}

print_header() {
  printf '%s%sDotfiles command guide%s\n' "$BLUE" "$BOLD" "$RESET"
  printf '%s  help all | help <name> | help ollama%s\n' "$DIM" "$RESET"
  printf '\n'
}

print_section() {
  local kind="$1"
  local title="$2"
  local section_file="$TMP_DIR/${kind}.tsv"

  awk -F '\t' -v kind="$kind" '$1 == kind { print $0 }' "$RECORDS_FILE" | sort -t $'\t' -k2,2 >"$section_file"

  if [[ ! -s "$section_file" ]]; then
    return 0
  fi

  printf '%s%s%s%s\n' "$CYAN" "$BOLD" "$title" "$RESET"

  awk -F '\t' -v bold="$BOLD" -v reset="$RESET" '
    {
      rows[NR] = $0
      if (length($2) > width) {
        width = length($2)
      }
    }

    END {
      for (i = 1; i <= NR; i++) {
        split(rows[i], parts, "\t")
        printf "  %s%-*s%s  %s\n", bold, width, parts[2], reset, parts[3]
      }
    }
  ' "$section_file"

  printf '\n'
}

append_named_record() {
  local name="$1"
  local section_file="$2"

  if [[ "$name" == "ollama" ]]; then
    printf 'topic\tollama\tLoad local Ollama service instructions when needed\thelp ollama\thelp\n' >>"$section_file"
    return 0
  fi

  awk -F '\t' -v name="$name" '
    tolower($2) == tolower(name) {
      print $0
      exit
    }
  ' "$RECORDS_FILE" >>"$section_file"
}

print_workflow_section() {
  local title="$1"
  local section_file
  shift

  section_file="$(mktemp "$TMP_DIR/workflow.XXXXXX")"

  local name
  for name in "$@"; do
    append_named_record "$name" "$section_file"
  done

  if [[ ! -s "$section_file" ]]; then
    return 0
  fi

  printf '%s%s%s%s\n' "$CYAN" "$BOLD" "$title" "$RESET"

  awk -F '\t' -v bold="$BOLD" -v reset="$RESET" '
    {
      rows[NR] = $0
      if (length($2) > width) {
        width = length($2)
      }
    }

    END {
      for (i = 1; i <= NR; i++) {
        split(rows[i], parts, "\t")
        printf "  %s%-*s%s  %s\n", bold, width, parts[2], reset, parts[3]
      }
    }
  ' "$section_file"

  printf '\n'
}

print_workflows() {
  print_header
  print_workflow_section "AI and editing" c copilot llm ee
  print_workflow_section "Repo work" flow repo commit
  print_workflow_section "Meetings and brain" am
  print_workflow_section "Remote machines" fixorb wasp
  print_workflow_section "On-demand instructions" ollama
  printf '%s  Use help all for the full source inventory, including under-the-hood helpers.%s\n' "$DIM" "$RESET"
}

print_all() {
  print_header
  print_section "alias" "ALIASES"
  print_section "function" "FUNCTIONS"
  print_section "script" "SCRIPTS"
}

print_ollama_help() {
  printf '%s%sOllama%s\n' "$BLUE" "$BOLD" "$RESET"
  printf '  %swhen:%s On-demand local model service, not a regular daily command.\n' "$DIM" "$RESET"
  printf '  %sstatus:%s ollama-service status\n' "$DIM" "$RESET"
  printf '  %sstart:%s  ollama-service start\n' "$DIM" "$RESET"
  printf '  %sstop:%s   ollama-service stop\n' "$DIM" "$RESET"
  printf '  %slogs:%s   ollama-service log\n' "$DIM" "$RESET"
  printf '\n'
}

print_match() {
  local section_file="$TMP_DIR/match.tsv"

  awk -F '\t' -v query_lower="$QUERY_LOWER" '
    tolower($2) == query_lower { print $0 }
  ' "$RECORDS_FILE" >"$section_file"

  if [[ ! -s "$section_file" ]]; then
    printf '%sNo custom alias, function, or script named "%s".%s\n' "$YELLOW" "$QUERY" "$RESET" >&2
    exit 1
  fi

  while IFS=$'\t' read -r kind name description value file; do
    printf '%s%s%s%s\n' "$BLUE" "$BOLD" "$name" "$RESET"
    printf '  %skind:%s %s\n' "$DIM" "$RESET" "$kind"
    printf '  %ssource:%s %s\n' "$DIM" "$RESET" "$file"
    printf '  %ssummary:%s %s\n' "$DIM" "$RESET" "$description"
    if [[ "$kind" == "alias" ]]; then
      printf '  %scommand:%s %s\n' "$DIM" "$RESET" "$value"
    elif [[ "$kind" == "script" ]]; then
      printf '  %scommand:%s %s\n' "$DIM" "$RESET" "$value"
    fi
    printf '\n'
  done <"$section_file"
}

collect_shell_records
collect_script_records

case "$QUERY_LOWER" in
  "" )
    print_workflows
    ;;
  all )
    print_all
    ;;
  workflow|workflows)
    print_workflows
    ;;
  ollama )
    print_ollama_help
    ;;
  alias|aliases)
    print_header
    print_section "alias" "ALIASES"
    ;;
  function|functions)
    print_header
    print_section "function" "FUNCTIONS"
    ;;
  script|scripts)
    print_header
    print_section "script" "SCRIPTS"
    ;;
  *)
    print_match
    ;;
esac
