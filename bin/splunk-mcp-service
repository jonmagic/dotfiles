#!/usr/bin/env bash
# Long-lived Splunk MCP server watchdog for Copilot CLI.
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

DOCKER="${DOCKER:-$(command -v docker)}"
IMAGE="${IMAGE:-splunk-mcp-server:fastmcp-pinned}"
NAME="${NAME:-splunk-mcp}"
PORT="${PORT:-8001}"
ENV_FILE="${ENV_FILE:-$HOME/.config/splunk-mcp/splunk-mcp.env}"
CHECK_INTERVAL="${CHECK_INTERVAL:-30}"
FAILURES_BEFORE_RESTART="${FAILURES_BEFORE_RESTART:-3}"
RESTARTS_BEFORE_FIXORB="${RESTARTS_BEFORE_FIXORB:-2}"
DOCKER_FAILURES_BEFORE_FIXORB="${DOCKER_FAILURES_BEFORE_FIXORB:-6}"
FIXORB="${FIXORB:-$HOME/.dotfiles/bin/fixorb}"
FIXORB_COOLDOWN="${FIXORB_COOLDOWN:-600}"
OPENAPI_TIMEOUT="${OPENAPI_TIMEOUT:-10}"
MCP_PROBE_TIMEOUT="${MCP_PROBE_TIMEOUT:-20}"

log() {
  echo "$(date '+%Y-%m-%dT%H:%M:%S') $*"
}

run_with_timeout() {
  local seconds="$1"
  shift
  local tmp status cmdpid guardpid
  tmp="$(mktemp -t splunk-mcp.XXXXXX)"

  "$@" >"$tmp" 2>&1 &
  cmdpid=$!

  (
    sleep "$seconds"
    if kill -0 "$cmdpid" 2>/dev/null; then
      kill "$cmdpid" 2>/dev/null || true
      echo "__TIMEOUT__" >>"$tmp"
    fi
  ) &
  guardpid=$!

  wait "$cmdpid" 2>/dev/null || status=$?
  status="${status:-0}"
  kill "$guardpid" 2>/dev/null || true
  wait "$guardpid" 2>/dev/null || true

  cat "$tmp"
  rm -f "$tmp"
  return "$status"
}

docker_ready() {
  run_with_timeout 10 "$DOCKER" info >/dev/null
}

maybe_fix_orbstack() {
  local now
  now="$(date +%s)"
  FIXORB_RAN=0

  if [[ ! -x "$FIXORB" ]]; then
    return 0
  fi

  if (( now - LAST_FIXORB_AT < FIXORB_COOLDOWN )); then
    return 0
  fi

  LAST_FIXORB_AT="$now"
  FIXORB_RAN=1
  log "running fixorb to recover OrbStack"
  export ORB_BIN="${ORB_BIN:-$(command -v orb 2>/dev/null || true)}"
  run_with_timeout 180 "$FIXORB" --force || true
}

wait_for_docker() {
  local failures=0

  until docker_ready; do
    failures=$((failures + 1))
    log "waiting for docker daemon..."

    if (( failures >= DOCKER_FAILURES_BEFORE_FIXORB )); then
      maybe_fix_orbstack
      failures=0
    fi

    sleep 5
  done
}

container_running() {
  [[ "$("$DOCKER" inspect -f '{{.State.Running}}' "$NAME" 2>/dev/null || true)" == "true" ]]
}

endpoint_healthy() {
  /usr/bin/curl --connect-timeout 3 --max-time "$OPENAPI_TIMEOUT" -fsS "http://127.0.0.1:${PORT}/openapi.json" >/dev/null
}

mcp_healthy() {
  "$DOCKER" exec "$NAME" /bin/sh -lc '
    set -eu
    python - <<'"'"'PY'"'"'
import asyncio
import os

from mcp import ClientSession
from mcp.client.sse import sse_client


async def main():
    port = os.environ.get("FASTMCP_PORT", "8001")
    async with sse_client(f"http://127.0.0.1:{port}/sse") as (read, write):
        async with ClientSession(read, write) as session:
            await session.initialize()
            result = await session.call_tool("ping", {})
            if getattr(result, "isError", False):
                raise SystemExit(1)


asyncio.run(asyncio.wait_for(main(), timeout=float(os.environ.get("MCP_PROBE_TIMEOUT", "20"))))
PY
  ' >/dev/null
}

splunk_reachable() {
  "$DOCKER" exec "$NAME" /bin/sh -lc '
    set -eu
    getent hosts "$SPLUNK_HOST" >/dev/null
    code="$(curl -sS --connect-timeout 5 --max-time 10 -o /dev/null -w "%{http_code}" \
      "${SPLUNK_SCHEME:-https}://${SPLUNK_HOST}:${SPLUNK_PORT:-443}/services/server/info")"
    case "$code" in
      200|401|403) exit 0 ;;
      *) echo "unexpected Splunk HTTP ${code}" >&2; exit 1 ;;
    esac
  ' >/dev/null
}

start_container() {
  wait_for_docker

  log "starting ${NAME}"
  "$DOCKER" rm -f "$NAME" >/dev/null 2>&1 || true
  "$DOCKER" run -d --name "$NAME" \
    --restart unless-stopped \
    --health-cmd "curl -fsS --connect-timeout 3 --max-time ${OPENAPI_TIMEOUT} http://127.0.0.1:${PORT}/openapi.json >/dev/null || exit 1" \
    --health-interval 30s \
    --health-timeout "$((OPENAPI_TIMEOUT + 2))s" \
    --health-retries 3 \
    --health-start-period 10s \
    --dns=100.100.100.100 \
    -p 127.0.0.1:${PORT}:${PORT} \
    -e MCP_PROBE_TIMEOUT="$MCP_PROBE_TIMEOUT" \
    --env-file "$ENV_FILE" \
    "$IMAGE" python splunk_mcp.py sse >/dev/null
}

LAST_FIXORB_AT=0
FIXORB_RAN=0
health_failures=0
restart_attempts=0

start_container

while true; do
  sleep "$CHECK_INTERVAL"

  if ! docker_ready; then
    log "docker daemon health check failed"
    maybe_fix_orbstack
    health_failures=0
    restart_attempts=0
    continue
  fi

  if ! container_running; then
    log "${NAME} is not running"
    start_container
    health_failures=0
    restart_attempts=0
    continue
  fi

  if endpoint_healthy && mcp_healthy && splunk_reachable; then
    health_failures=0
    restart_attempts=0
    continue
  fi

  health_failures=$((health_failures + 1))
  log "${NAME} health check failed (${health_failures}/${FAILURES_BEFORE_RESTART})"

  if (( health_failures >= FAILURES_BEFORE_RESTART )); then
    if endpoint_healthy; then
      restart_attempts=0
    else
      restart_attempts=$((restart_attempts + 1))

      if (( restart_attempts >= RESTARTS_BEFORE_FIXORB )); then
        log "${NAME} endpoint unreachable after ${restart_attempts} restart(s); escalating to fixorb (likely wedged OrbStack VM network)"
        maybe_fix_orbstack
        if (( FIXORB_RAN == 1 )); then
          restart_attempts=0
        fi
      fi
    fi

    log "restarting ${NAME} after repeated health check failures"
    start_container
    health_failures=0
  fi
done
