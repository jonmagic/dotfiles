#!/usr/bin/env ruby
# frozen_string_literal: true

# Convert VTT (WebVTT) subtitle files to a readable transcript format
# Usage: vtt2transcript path/to/file.vtt

require 'time'

def parse_timestamp(timestamp)
  # Parse timestamps like "00:00:03.488" or "00:00:07.088"
  parts = timestamp.strip.split(':')
  hours = parts[0].to_i
  minutes = parts[1].to_i
  seconds = parts[2].to_f.to_i

  format('%02d:%02d:%02d', hours, minutes, seconds)
end

def parse_speaker_and_text(line)
  # Extract speaker and text from lines like "<v Jonathan Hoyt>Transcript started. How you doing?</v>"
  if line =~ /<v\s+([^>]+)>(.+?)(?:<\/v>)?$/
    speaker = $1.strip
    text = $2.strip
    [speaker, text]
  else
    [nil, line.strip]
  end
end

def extract_all_text(line)
  # Remove all <v> and </v> tags and return the text
  cleaned = line.gsub(/<\/?v[^>]*>/, '').strip
  cleaned.empty? ? nil : cleaned
end

def convert_vtt(file_path)
  unless File.exist?(file_path)
    puts "Error: File not found: #{file_path}"
    exit 1
  end

  content = File.read(file_path)
  lines = content.split("\n")

  current_speaker = nil
  current_timestamp = nil
  current_text = []

  lines.each do |line|
    line = line.strip
    next if line.empty?
    next if line == 'WEBVTT'
    next if line =~ /^[a-f0-9\-\/]+$/ # Skip IDs like "a74c5c78-a5a0-4d71-9bc2-9cd64c5c0306/30-0"

    # Check if this is a timestamp line
    if line =~ /(\d{2}:\d{2}:\d{2}\.\d{3})\s*-->\s*(\d{2}:\d{2}:\d{2}\.\d{3})/
      start_time = parse_timestamp($1)

      # If we have accumulated text, output it before starting a new block
      if current_speaker && !current_text.empty?
        puts "[#{current_speaker}] #{current_timestamp}"
        puts current_text.join("\n")
        puts
        current_text = []
      end

      current_timestamp = start_time
    else
      # This is a text line - check if it has a speaker tag
      if line =~ /<v\s+([^>]+)>/
        speaker, text = parse_speaker_and_text(line)

        # If speaker changed, output previous block
        if current_speaker && speaker != current_speaker && !current_text.empty?
          puts "[#{current_speaker}] #{current_timestamp}"
          puts current_text.join("\n")
          puts
          current_text = []
        end

        current_speaker = speaker if speaker

        # Extract the actual text content (removing all tags)
        text_content = extract_all_text(line)
        current_text << text_content if text_content && !text_content.empty?
      else
        # Plain text line without speaker tag - add to current speaker's text
        text_content = extract_all_text(line)
        current_text << text_content if text_content && !text_content.empty?
      end
    end
  end

  # Output any remaining text
  if current_speaker && !current_text.empty?
    puts "[#{current_speaker}] #{current_timestamp}"
    puts current_text.join("\n")
  end
end

if ARGV.empty?
  puts "Usage: #{File.basename($0)} path/to/file.vtt"
  exit 1
end

convert_vtt(ARGV[0])
