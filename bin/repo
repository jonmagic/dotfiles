#!/bin/bash

normalize_repo_url() {
  local repo="$1"

  if [[ $repo =~ ^git@([^:]+):(.+)$ ]]; then
    printf 'https://%s/%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]%.git}"
  elif [[ $repo =~ ^ssh://git@([^/]+)/(.+)$ ]]; then
    printf 'https://%s/%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]%.git}"
  elif [[ $repo =~ ^https?://([^/]+)/(.+)$ ]]; then
    printf 'https://%s/%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]%.git}"
  else
    printf '%s\n' "${repo%.git}"
  fi
}

if [[ $OSTYPE == darwin* ]]; then
  REPO=$(git config --local --get remote.origin.url)
  BRANCH=$(git branch --show-current)

  if [[ -z $REPO ]]; then
    echo "No origin remote found for this repository"
    exit 1
  fi

  if [[ -z $BRANCH ]]; then
    echo "Unable to determine the current branch"
    exit 1
  fi

  open "$(normalize_repo_url "$REPO")/compare/$BRANCH"
else
  echo "Unavailable on this system"
fi
