if [[ $OSTYPE == darwin* ]]; then
  export RUBY_CFLAGS="-Wno-error=implicit-function-declaration"

  # All Go files and caches live in ~/code/*
  export GOPATH="$HOME/code/go/go"                 # workspace (rarely needed with modules, still useful)
  export GOMODCACHE="$HOME/code/go/pkg/mod"        # module cache
  export GOCACHE="$HOME/code/.cache/go/go-build"   # build cache
  export GOBIN="$HOME/code/go/bin"                 # where `go install` puts binaries

  export ONECLI_API_HOST=http://localhost:10254

  # Keep Ollama models loaded in memory (avoid cold starts)
  export OLLAMA_KEEP_ALIVE="-1"
fi
