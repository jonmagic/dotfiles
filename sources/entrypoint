autoload -U +X bashcompinit && bashcompinit

safe_source() {
  local file="$1"
  if [[ -f "$file" ]]; then
    source "$file"
    return 0
  fi
  return 1
}

safe_source "$HOME/.local/bin/env"

if [[ $OSTYPE = darwin* ]]; then
  if [[ $CPUTYPE -eq arm64 ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  else
    echo "brew not installed in intel arch"
  fi
fi

load_full_config() {
  safe_source "$HOME/.dotfiles/sources/path"
  safe_source "$HOME/.dotfiles/sources/mise.zsh"
  safe_source "$HOME/.dotfiles/sources/aliases"
  safe_source "$HOME/.dotfiles/sources/functions.zsh"
  safe_source "$HOME/.dotfiles/sources/env_variables"
  safe_source "$HOME/.dotfiles/sources/env_secrets"
  safe_source "$HOME/.dotfiles/sources/terminal"
  safe_source "$HOME/.dotfiles/sources/ghostty-colors.zsh"
  # safe_source $HOME/.config/op/plugins.sh
  # safe_source $HOME/.cargo/env

  # The following lines have been added by Docker Desktop to enable Docker CLI completions.
  fpath=(/Users/jonmagic/.docker/completions $fpath)
  autoload -Uz compinit
  compinit
  # End of Docker CLI completions

  if [[ -o interactive ]] && [[ -t 1 ]] && [[ -z "${DOTFILES_HELP_DISABLE:-}" ]] && [[ -z "${DOTFILES_HELP_SHOWN:-}" ]]; then
    export DOTFILES_HELP_SHOWN=1
    if [[ -x "$HOME/.dotfiles/bin/help" ]]; then
      "$HOME/.dotfiles/bin/help" --startup
    fi
  fi
}

if [[ -n "$SSH_CONNECTION" && -z "${DOTFILES_FULL_SSH:-}" ]]; then
  # Remote SSH session — lightweight config only unless explicitly opted in.
  safe_source "$HOME/.dotfiles/sources/remote"
else
  # Local session, or an interactive remote session that wants the full prompt/theme.
  load_full_config
fi
