command_exists() {
  command -v "$1" >/dev/null 2>&1
}

executable_exists() {
  [[ -x "$1" ]]
}

# Visual Studio Code
if command_exists code; then
  alias e=code
fi

# Visual Studio Code Insiders
if command_exists code-insiders; then
  alias ee=code-insiders
fi

# Archive meeting
if executable_exists "$HOME/code/jonmagic/scripts/bin/archive-meeting"; then
  am() {
    local archive_meeting_model="${ARCHIVE_MEETING_MODEL:-gpt-5.5}"
    local archive_meeting_reasoning_effort="${ARCHIVE_MEETING_REASONING_EFFORT:-medium}"
    ~/code/jonmagic/scripts/bin/archive-meeting \
      --brain-dir ~/Brain \
      --executive-summary-prompt-path ~/code/jonmagic/prompts/summarize/zoom-transcript-executive-summary.md \
      --detailed-notes-prompt-path ~/code/jonmagic/prompts/summarize/transcript-meeting-notes.md \
      --model "$archive_meeting_model" \
      --reasoning-effort "$archive_meeting_reasoning_effort" \
      "$@"
  }
fi

# Create semantic commit
if command_exists copilot; then
  commit() {
    local msg=$(copilot -p "$(cat ~/code/jonmagic/prompts/generate/commit-message.md)

$(git diff --cached)" | sed '/^```/d')
    git commit -m "$msg"
  }
fi

# Prepare Pull Request
if executable_exists "$HOME/code/jonmagic/scripts/bin/prepare-pull-request"; then
  alias ppr='~/code/jonmagic/scripts/bin/prepare-pull-request --base-branch main --pr-body-prompt-path ~/code/jonmagic/prompts/generate/pull-request-body.md'
fi

# Flow
if executable_exists "$HOME/code/jonmagic/flow/script/flow"; then
  alias flow="$HOME/code/jonmagic/flow/script/flow"
fi

# Git branches by most recent commit date
if command_exists git && command_exists llm; then
  alias gbb='git for-each-ref --sort=-committerdate --format="%(refname:short) - %(committerdate:short) - %(authorname) - %(subject)" refs/heads/ | llm "sort newest to oldest and format as a markdown table"'
fi

