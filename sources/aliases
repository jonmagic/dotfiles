command_exists() {
  command -v "$1" >/dev/null 2>&1
}

executable_exists() {
  [[ -x "$1" ]]
}

_command_path() {
  whence -p "$1" 2>/dev/null || command -v "$1" 2>/dev/null
}

# Visual Studio Code Insiders
if command_exists code-insiders; then
  alias ee=code-insiders
