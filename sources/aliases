# Create semantic commit from staged changes
if command_exists git && command_exists llm; then
  commit() {
    local prompt_file="$HOME/code/jonmagic/prompts/generate/commit-message.md"
    local model="${COMMIT_LLM_MODEL:-${LLM_COPILOT_MODEL:-github_copilot/claude-opus-4.6}}"
    local max_diff_bytes="${COMMIT_LLM_MAX_DIFF_BYTES:-200000}"
    local diff diff_bytes raw_msg msg line_count

    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      echo "Not inside a git repository." >&2
      return 1
    fi

    if [[ ! -f "$prompt_file" ]]; then
      echo "Commit prompt not found at $prompt_file" >&2
      return 1
    fi

    diff="$(git diff --cached)"
    if [[ -z "$diff" ]]; then
      echo "No staged changes to commit." >&2
      return 1
    fi

    diff_bytes="$(printf '%s' "$diff" | wc -c | tr -d '[:space:]')"
    if (( diff_bytes > max_diff_bytes )); then
      echo "Staged diff is ${diff_bytes} bytes, over COMMIT_LLM_MAX_DIFF_BYTES=${max_diff_bytes}." >&2
      echo "Commit manually or raise COMMIT_LLM_MAX_DIFF_BYTES for this run." >&2
      return 1
    fi

    raw_msg="$({ cat "$prompt_file"; printf '\n\n%s\n' "$diff"; } | llm --no-log --no-stream -m "$model")" || return
    msg="$(printf '%s\n' "$raw_msg" |
      sed '/^```/d' |
      sed -E "1s/^(Commit message:|Here is( a)? commit message:|Here's( a)? commit message:)[[:space:]]*//I" |
      awk 'NF { started = 1 } started { lines[++n] = $0 } END { while (n > 0 && lines[n] ~ /^[[:space:]]*$/) n--; for (i = 1; i <= n; i++) print lines[i] }')"

    if [[ -z "$msg" ]]; then
      echo "llm returned an empty commit message." >&2
      return 1
    fi

    line_count="$(printf '%s\n' "$msg" | awk 'END { print NR }')"
    if (( line_count > 20 )); then
      echo "llm returned a ${line_count}-line commit message; refusing to commit." >&2
      printf '%s\n' "$msg" >&2
      return 1
    fi

    if [[ -n "${COMMIT_LLM_DRY_RUN:-}" ]]; then
      printf '%s\n' "$msg"
      return 0
    fi

    printf '%s\n' "$msg" | git commit -F -
  }
fi

