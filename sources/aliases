# Archive meeting
if executable_exists "$HOME/code/jonmagic/scripts/bin/archive-meeting"; then
  am() {
    local archive_meeting_model="${ARCHIVE_MEETING_MODEL:-github_copilot/claude-opus-4.6}"
    ~/code/jonmagic/scripts/bin/archive-meeting \
      --brain-dir ~/Brain \
