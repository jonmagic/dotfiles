# Personal SSH to remote machines; uses direct SSH unless the work Tailscale profile needs the OrbStack proxy.
if command_exists ssh; then
  _personal_tailnet_ssh_route() {
    case "${DOTFILES_PERSONAL_SSH_ROUTE:-auto}" in
      direct|ssh)
        printf '%s\n' ssh
        return 0
        ;;
      tsp|orbstack)
        printf '%s\n' tsp
        return 0
        ;;
      auto|"")
        ;;
      *)
        echo "DOTFILES_PERSONAL_SSH_ROUTE must be auto, direct, ssh, tsp, or orbstack." >&2
        return 2
        ;;
    esac

    local tailscale_bin
    tailscale_bin="$(_command_path tailscale || true)"
    if [[ -z "$tailscale_bin" && -x "$HOME/.dotfiles/bin/tailscale" ]]; then
      tailscale_bin="$HOME/.dotfiles/bin/tailscale"
    fi

    if [[ -n "$tailscale_bin" ]] && command_exists tsp-ssh && "$tailscale_bin" switch --list 2>/dev/null | awk '
      NR == 1 { next }
      {
        account = $3
        active = account ~ /\*$/
        sub(/\*$/, "", account)

        if (active && ($2 == "github.com" || account == "work" || account == "jonmagic@github.com")) {
          found = 1
          exit
        }
      }

      END { exit found ? 0 : 1 }
    '; then
      printf '%s\n' tsp
      return 0
    fi

    printf '%s\n' ssh
  }

  _personal_tailnet_ssh() {
    local route
    route="$(_personal_tailnet_ssh_route)" || return

    if [[ "$route" == tsp ]]; then
      tsp-ssh "$@"
    else
      ssh "$@"
    fi
  }

  # SSH to the NAS, using direct SSH unless work Tailscale needs the OrbStack proxy.
  nas() {
    if [[ $# -eq 0 ]]; then
      _personal_tailnet_ssh -tt tnas 'stty sane 2>/dev/null; export LS_COLORS="di=01;34:ln=01;36:so=01;35:pi=33:ex=01;32:bd=01;33:cd=01;33:su=37;41:sg=01;33:tw=01;34:ow=01;34"; exec "${SHELL:-/bin/sh}" -l'
    else
      _personal_tailnet_ssh tnas "$@"
    fi
  }

  # SSH to wasp, using direct SSH unless work Tailscale needs the OrbStack proxy.
  alias wasp='_personal_tailnet_ssh wasp'

  _wasp_tmux_remote_command() {
    local session="$1"

    cat <<EOF
tmux start-server
tmux set-environment -g DOTFILES_FULL_SSH 1
tmux set-environment -g DOTFILES_HELP_DISABLE 1
tmux set-environment -g COLORTERM truecolor
tmux set-option -g default-terminal tmux-256color
tmux set-option -g mouse off
tmux set-option -g status-keys vi
tmux set-option -g mode-keys vi
tmux set-option -g set-clipboard external
tmux show-option -gqv terminal-features 2>/dev/null | grep -Fq '*:clipboard' || tmux set-option -gq -a terminal-features ',*:clipboard' 2>/dev/null || true
tmux has-session -t ${session} 2>/dev/null || tmux new-session -d -s ${session} "env DOTFILES_FULL_SSH=1 DOTFILES_HELP_DISABLE=1 COLORTERM=truecolor zsh -l"
tmux set-option -t ${session} status off
tmux attach-session -t ${session}
EOF
  }

  _wasp_tmux() {
    local session="$1"
    if [[ ! "$session" =~ ^[1-9]$ ]]; then
      echo "Usage: w<1-9>" >&2
      return 2
    fi

    local remote_command="$(_wasp_tmux_remote_command "$session")"
    _personal_tailnet_ssh wasp -t "zsh -lc ${(qq)remote_command}"
  }

  for session in {1..9}; do
    alias "w${session}=_wasp_tmux ${session}"
  done
  unset session
fi
