{
  "name": "jonmagic-brain",
  "displayName": "Jonmagic Brain",
  "description": "Utilities for my Brain repo (Daily Projects, etc.)",
  "version": "0.0.0",
  "publisher": "jonmagic",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonmagic/dotfiles",
    "directory": "packages/vscode"
  },
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:jonmagic.brain.createDailyProjectNote"
  ],
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jonmagic.brain.createDailyProjectNote",
        "title": "Jonmagic: Create Daily Project Note"
      }
    ]
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@jonmagic/brain-core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.8.2"
  }
}
